  "tokenColors": [
    {
      "name": "Global foreground",
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#fbf8ff"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#69676c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#fce566"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#fc618d"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#fc618d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#fc618d"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.assignment"
      ],
      "settings": {
        "foreground": "#fc618d"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#5ad4e6"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#fd9353",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function definitions",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7bd88f"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#7bd88f"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#fbf8ff"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": {
        "foreground": "#fd9353",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#e8e4f0"
      }
    },
    {
      "name": "this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#fc618d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#948ae3"
      }
    },
    {
      "name": "Import / export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#fc618d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition.block",
        "punctuation.separator"
      ],
      "settings": {
        "foreground": "#8b888f"
      }
    },
    {
      "name": "HTML tags",
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag"
      ],
      "settings": {
        "foreground": "#fc618d"
      }
    },
    {
      "name": "HTML attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7bd88f"
      }
    },
    {
      "name": "HTML attribute values",
      "scope": [
        "meta.attribute string"
      ],
      "settings": {
        "foreground": "#fce566"
      }
    },
    {
      "name": "CSS property names",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#5ad4e6"
      }
    },
    {
      "name": "CSS property values",
      "scope": [
        "meta.property-value",
        "meta.property-value support.constant"
      ],
      "settings": {
        "foreground": "#fce566"
      }
    },
    {
      "name": "CSS class / id",
      "scope": [
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#7bd88f"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "source.json support.type.property-name",
        "meta.structure.dictionary.json string.quoted"
      ],
      "settings": {
        "foreground": "#fc618d"
      }
    },
    {
      "name": "JSON values",
      "scope": [
        "source.json meta.structure.dictionary.json > value string"
      ],
      "settings": {
        "foreground": "#fce566"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#fc618d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fd9353",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#5ad4e6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown inline code",
      "scope": [
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#7bd88f"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#5ad4e6"
      }
    },
    {
      "name": "Markdown blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#69676c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fbf8ff",
        "background": "#fc618d88"
      }
    },
    {
      "name": "Built-in",
      "scope": [
        "support.function.builtin",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#948ae3"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#69676c"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": {
      "foreground": "#5ad4e6"
    },
    "interface": {
      "foreground": "#5ad4e6",
      "fontStyle": "italic"
    },
    "enum": {
      "foreground": "#5ad4e6"
    },
    "enumMember": {
      "foreground": "#948ae3"
    },
    "function": {
      "foreground": "#7bd88f"
    },
    "method": {
      "foreground": "#7bd88f"
    },
    "parameter": {
      "foreground": "#fd9353",
      "fontStyle": "italic"
    },
    "variable": {
      "foreground": "#fbf8ff"
    },
    "variable.readonly": {
      "foreground": "#e8e4f0"
    },
    "property": {
      "foreground": "#e8e4f0"
    },
    "type": {
      "foreground": "#5ad4e6"
    },
    "typeParameter": {
      "foreground": "#fc618d",
      "fontStyle": "italic"
    },
    "namespace": {
      "foreground": "#5ad4e6"
    },
    "keyword": {
      "foreground": "#fc618d"
    },
    "decorator": {
      "foreground": "#fd9353",
      "fontStyle": "italic"
    },
    "comment": {
      "foreground": "#69676c",
      "fontStyle": "italic"
    },
    "string": {
      "foreground": "#fce566"
    },
    "number": {
      "foreground": "#948ae3"
    },
    "regexp": {
      "foreground": "#fc618d"
    },
    "operator": {
      "foreground": "#fc618d"
    },
    "macro": {
      "foreground": "#fd9353"
    },
    "label": {
      "foreground": "#5ad4e6"
    }
  }
}